Program = Gap (Statement Gap)*
Statement = EmptyStatement | RegularBlock
RegularBlock = '{' Gap (Statement Gap)* '}'
EmptyStatement = ';'
Gap = Whitespace | Comment
Comment = SinglelineComment | MultilineComment
Whitespace = ' ' | '\t' | Newline
Newline = '\r\n' | '\r' | '\n'
SinglelineComment = '//' ! SinglelineCommentBody
MultilineComment = '/*' ! MultilineCommentBody '*/'
