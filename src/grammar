# Program

Program -> SepOpt (Statement SepOpt)*
Statement ->
    EmptyStatement
    | RegularBlock
    | AssemblerBlock
RegularBlock -> '{' ^ SepOpt (Statement SepOpt)* '}'
EmptyStatement -> ';'
SepOpt -> (Whitespace | Comment)*
Sep -> (Whitespace | Comment)+
Comment -> SinglelineComment | MultilineComment
Whitespace -> ' ' | '\t' | Newline
Newline -> '\r\n' | '\r' | '\n'
SinglelineComment -> '//' SinglelineCommentBody
MultilineComment -> '/*' MultilineCommentBody ^ '*/'

# AssemblerBlock

AssemblerBlock -> `asm` SepOpt '{' ^ SepOpt (AssemblerStatement End)* '}'
AssemblerStatement ->
    StandaloneAssemblerLabel
    | AssemblerOperation
    | AssemblerInstruction
StandaloneAssemblerLabel -> AssemblerLabel
AssemblerLabel -> AssemblerLabelName ':'
AssemblerLabelName -> /^[_a-zA-Z][_a-zA-Z0-9]*/

# End

End -> (Sep & GotNewline) | (SepOpt ';' SepOpt) | (SepOpt ?'}')

return this.try(() => {
            let wcc = this.wcc();
            return (
                this.isEndOfFile()
                || this.eat(';')
                || wcc.gotNewline()
                || this.look(() => this.eat('}'))
            );
        });

sequence(
        '',
        'End',
    ),
    (token) {
        let value = token.lexer.eatIdentifier({
            upperCase: true,
            underscore: true,
        });
        if (value === null) {
            return null;
        }
        return token.finalize({rawValue: value});
    },